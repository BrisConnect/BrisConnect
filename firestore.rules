rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authEmailLower() {
      return request.auth.token.email.lower();
    }

    function isSelf(email) {
      return signedIn()
          && request.auth.token.email != null
          && authEmailLower() == email.lower();
    }

    function isAdmin() {
      return signedIn()
          && request.auth.token.email != null
          && exists(/databases/$(database)/documents/admins/$(authEmailLower()))
          && get(/databases/$(database)/documents/admins/$(authEmailLower())).data.active == true
          && (
            !('role' in get(/databases/$(database)/documents/admins/$(authEmailLower())).data)
            || get(/databases/$(database)/documents/admins/$(authEmailLower())).data.role == 'admin'
          );
    }

            function isApprovedLocal() {
          return signedIn()
              && request.auth.token.email != null
              && exists(/databases/$(database)/documents/local_users/$(authEmailLower()))
              && get(/databases/$(database)/documents/local_users/$(authEmailLower())).data.approvalStatus == 'approved';
            }

    // Startup connectivity check used by the app splash probe.
    match /_connectivity_probe/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Public event browsing for visitor/local portals.
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin()
          || (
            isApprovedLocal()
            && request.resource.data.reviewStatus == 'pending'
            && request.resource.data.createdByLocalEmail.lower() == authEmailLower()
          );
      allow update, delete: if isAdmin();
    }

    // Discovery catalog used by Home/Visitor discover feeds.
    match /discover_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Approved attractions displayed on the attractions map.
    match /attractions/{attractionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Seeder metadata for idempotent discovery data writes.
    match /seed_metadata/{seedId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Visitor profile documents use lowercase email as document ID.
    match /visitor_users/{email} {
      allow create: if isSelf(email);
      allow read, update, delete: if isSelf(email) || isAdmin();
    }

    // Local profile documents use lowercase email as document ID.
    match /local_users/{email} {
      allow create: if isSelf(email);
      allow read, update, delete: if isSelf(email) || isAdmin();
    }

    // Admin can manage user active/deactivation status via these permissions.

    // Admin role documents keyed by lowercase email.
    match /admins/{email} {
      allow read: if isSelf(email) || isAdmin();
      allow write: if isAdmin();
    }

    // Event reports submitted by visitors for inappropriate/problematic events.
    // Document ID convention: `${eventId}__${visitorEmailLower}`
    match /event_reports/{reportId} {
      // Visitors can create one report per event, admins can read/update for moderation.
      allow create: if signedIn()
          && request.auth.token.email != null
          && exists(/databases/$(database)/documents/visitor_users/$(authEmailLower()))
          && !exists(/databases/$(database)/documents/event_reports/$(reportId))
          && request.resource.data.visitorEmail is string
          && request.resource.data.visitorEmail.lower() == authEmailLower();
      allow read, update: if isAdmin();
    }

    // Notification history persisted per user.
    // Each document stores a single event-notification record linked by userEmail.
    match /user_notifications/{notificationId} {
      // Users can only read and update their own notification records
      allow read, update, delete: if signedIn()
          && request.auth.token.email != null
          && authEmailLower() == resource.data.userEmail.lower();
      // Creation is allowed when the authenticated user's email matches the record
      allow create: if signedIn()
          && request.auth.token.email != null
          && authEmailLower() == request.resource.data.userEmail.lower();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
