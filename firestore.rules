rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth != null && request.auth.token.email != null
          ? request.auth.token.email.lower()
          : null;
    }

    function isAdmin() {
      return authEmail() != null
        && exists(/databases/$(database)/documents/admins/$(authEmail()));
    }

    // ── Admin collection ──
    match /admins/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Local users ──
    // Dev: allow unauthenticated read/update for unsigned macOS builds where
    // Firebase Auth keychain access fails.
    match /local_users/{docId} {
      allow read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() && authEmail() == docId;
      allow update: if (isSignedIn() && authEmail() == docId) || isAdmin() || request.auth == null;
      allow delete: if isAdmin();
    }

    // ── Visitor users ──
    // Dev: allow unauthenticated read/update for unsigned macOS builds where
    // Firebase Auth keychain access fails.
    match /visitor_users/{docId} {
      allow read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() && authEmail() == docId;
      allow update: if (isSignedIn() && authEmail() == docId) || isAdmin() || request.auth == null;
      allow delete: if isAdmin();
    }

    // ── Events ──
    match /events/{eventId} {
      allow read: if true; // Allow public read
      allow create: if isSignedIn() || request.auth == null; // Dev: allow unauthenticated
      allow update: if isSignedIn()
        && (resource.data.createdByLocalEmail == authEmail() || isAdmin());
      allow delete: if isSignedIn()
        && (resource.data.createdByLocalEmail == authEmail() || isAdmin());
    }

    // ── Approved Attractions (for web app) ──
    match /approved_attractions/{docId} {
      allow read: if true; // Allow public read
      allow write: if isAdmin() || request.auth == null; // Dev: allow unauthenticated
    }

    // ── Attraction details ──
    match /attraction_details/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Event reports ──
    match /event_reports/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── App feedback ──
    match /app_feedback/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Mail queue (consumed by extensions) ──
    match /mail/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── SMS queue ──
    match /sms_queue/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── User notifications ──
    match /user_notifications/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Brisbane stories & voices (read-only, seeded server-side) ──
    match /brisbane_stories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /brisbane_voices/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Discover items (seeded, read by all) ──
    match /discover_items/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Seed metadata ──
    match /seed_metadata/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Counters (auto-increment IDs for feedback etc.) ──
    match /counters/{docId} {
      allow read, write: if isSignedIn();
    }

    // ── Config (event categories etc.) ──
    match /config/{docId} {
      allow read: if true; // Allow public read
      allow write: if isAdmin();
    }
    
    // ── Event categories (for web app) ──
    match /event_categories/{docId} {
      allow read: if true; // Allow public read
      allow write: if isAdmin() || request.auth == null; // Dev: allow unauthenticated
    }

    // ── Connectivity probe ──
    match /_connectivity_probe/{docId} {
      allow read: if isSignedIn();
    }

    // ── Business profiles (local business owner management) ──
    // Dev: allow unauthenticated create/update for unsigned macOS builds where
    // Firebase Auth keychain access fails. Restrict to authenticated owners
    // before production.
    match /businesses/{businessId} {
      allow read: if true; // Allow public read (all businesses visible)
      allow create: if (isSignedIn() && request.resource.data.ownerId == authEmail())
        || request.auth == null;
      allow update: if isSignedIn() && (
        resource.data.ownerId == authEmail()
        || isAdmin()
        // Any signed-in visitor may update the public rating aggregates after
        // submitting a review.
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['averageRating', 'reviewCount', 'rating', 'buzzRating', 'updatedAt'])
      ) || request.auth == null;
      allow delete: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );

      // Dev: nested reviews subcollection for unsigned macOS builds.
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth == null || isSignedIn();
        allow update, delete: if isSignedIn() || request.auth == null;
      }
    }

    // ── Reviews / Recommendations (visitor feedback on businesses) ──
    // Dev: allow unauthenticated reads/writes for unsigned macOS builds.
    match /reviews/{reviewId} {
      // Only show recommendations that are public (visible == true).
      allow read: if resource.data.visible == true || request.auth == null;

      // Authenticated visitors can create one recommendation per business.
      // Rate limits are enforced client-side; rules guarantee auth binding
      // and data shape so fake/spam payloads are rejected.
      // Dev: allow unauthenticated creates for unsigned macOS builds.
      allow create: if (isSignedIn()
        && request.resource.data.visitorId == request.auth.uid
        && request.resource.data.businessId is string
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() <= 500
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.buzzRating is int
        && request.resource.data.buzzRating >= 0
        && request.resource.data.buzzRating <= 5
        && request.resource.data.createdAt == request.time
        && request.resource.data.visible == true)
        || request.auth == null;

      // Owners can soft-delete their own recommendations. Admins can perform
      // any update (report, flag, restore, moderate).
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.visitorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deletedAt', 'deletedBy', 'visible', 'updatedAt'])
      );

      // Hard delete is reserved for admins only so history is preserved.
      allow delete: if isAdmin();
    }

    // ── Food businesses (public read, seeding allows unauthenticated write) ──
    match /food_businesses/{businessId} {
      allow read: if true; // Allow public read
      allow write: if isAdmin() || request.auth == null; // Dev: allow unauthenticated for seeding
    }

    // ── Crowd reports (public read, authenticated create with cooldown enforced client-side) ──
    match /crowd_reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['eventId', 'level', 'weight', 'timestamp'])
        && request.resource.data.eventId is string
        && request.resource.data.level is string
        && request.resource.data.weight is int
        && request.resource.data.timestamp is timestamp;
      allow update, delete: if false;
    }

    // ── Audience interactions (anonymised engagement analytics) ──
    // Business owners can read interactions for businesses they own.
    // Any signed-in visitor can record an anonymised view/save interaction.
    // Dev: allow unauthenticated reads for unsigned macOS builds.
    match /audience_interactions/{interactionId} {
      allow read: if (isSignedIn() && resource.data.ownerId == authEmail()) || request.auth == null;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['businessId', 'ownerId', 'visitorHash', 'type', 'timestamp'])
        && request.resource.data.businessId is string
        && request.resource.data.ownerId is string
        && request.resource.data.visitorHash is string
        && request.resource.data.type is string
        && request.resource.data.timestamp is timestamp;
      allow update, delete: if false;
    }

    // ── Business events (local business owner events) ──
    // Dev: allow unauthenticated reads for unsigned macOS builds.
    match /business_events/{eventId} {
      allow read: if (isSignedIn() && (
        resource.data.ownerId == authEmail() || resource.data.status == 'published'
      )) || request.auth == null;
      allow create: if isSignedIn() && request.resource.data.ownerId == authEmail();
      allow update: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );
    }

    // ── Promotions (local business owner promotions) ──
    // Dev: allow unauthenticated reads/writes for unsigned macOS builds.
    match /promotions/{promotionId} {
      allow read: if (isSignedIn() && resource.data.ownerId == authEmail()) || request.auth == null;
      allow create: if (isSignedIn() && request.resource.data.ownerId == authEmail()) || request.auth == null;
      allow update: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );
    }

    // ── AI-generated posts (drafts and published posts) ──
    // Published posts are public so they can appear in the Vendor Feed.
    // Drafts are only readable by their owner. Dev: unauthenticated fallbacks
    // remain for unsigned macOS builds.
    match /ai_generated_posts/{postId} {
      allow read: if resource.data.status == 'published'
        || (isSignedIn() && resource.data.ownerId == authEmail())
        || request.auth == null;
      allow create: if (isSignedIn() && request.resource.data.ownerId == authEmail()) || request.auth == null;
      allow update: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      ) || request.auth == null;
      allow delete: if isSignedIn() && (
        resource.data.ownerId == authEmail() || isAdmin()
      );
    }
  }
}
