<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:oel="http://schemas.microsoft.com/office/2019/extlst" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16du="http://schemas.microsoft.com/office/word/2023/wordml/word16du" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="5ABBCF2D" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:t>As a Local user, I want the Profile tab content to be clearly readable so that I can easily view my activity stats, notifications, and settings over the background image.</w:t></w:r></w:p><w:p w14:paraId="7207D72C" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Acceptance Criteria:</w:t></w:r></w:p><w:p w14:paraId="31D6AD6B" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Card backgrounds are opaque enough (≥0.96 alpha) that text does not blend into the background image.</w:t></w:r></w:p><w:p w14:paraId="13C7B438" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Section labels (MY ACTIVITY, NOTIFICATIONS, PREFERENCES, etc.) use a dark, high-contrast colour visible over the background.</w:t></w:r></w:p><w:p w14:paraId="6F5993B8" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The Profile tab has a semi-opaque container backing the full scrollable content area.</w:t></w:r></w:p><w:p w14:paraId="5A84EFB4" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Stat chips (Total, Pending, Approved, Rejected) are legible with distinct colour-coded numbers.</w:t></w:r></w:p><w:p w14:paraId="38ECC1F4" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>ListTile</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> titles and subtitles within cards are readable at normal viewing distance.</w:t></w:r></w:p><w:p w14:paraId="6DD98741" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The Profile tab must maintain a minimum contrast ratio of 4.5:1 between text and background to ensure readability for all users under standard viewing conditions.</w:t></w:r></w:p><w:p w14:paraId="20422ABF" w14:textId="4E3735B5" w:rsidR="00CB6579" w:rsidRDefault="00CB6579" w:rsidP="00A35FB7"/><w:p w14:paraId="2B040DA5" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:t>As a Local user, I want the background image (Kookaburra) to cover the entire screen so that the app has a cohesive, immersive visual identity.</w:t></w:r></w:p><w:p w14:paraId="558C3301" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Acceptance Criteria:</w:t></w:r></w:p><w:p w14:paraId="7E8D92D0" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The background image spans the full screen behind all tabs (Home, Map, My Events, Profile).</w:t></w:r></w:p><w:p w14:paraId="18463385" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>A gradient overlay tints the image to maintain brand warmth without washing out the photo.</w:t></w:r></w:p><w:p w14:paraId="583335D4" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The overlay is strong enough to keep foreground text readable but subtle enough to preserve the image.</w:t></w:r></w:p><w:p w14:paraId="3FA4EEEA" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The content sheet on the Home tab uses sufficient opacity (≥0.85) to separate content from background.</w:t></w:r></w:p><w:p w14:paraId="356E6C3D" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The background image and overlay must load and render within 2 seconds on standard mobile devices without affecting overall app performance.</w:t></w:r></w:p><w:p w14:paraId="01336068" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"/><w:p w14:paraId="23EB8A52" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">As a Local user, I want the </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AppBar</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> to blend seamlessly with the background image so that there is no visually jarring colour band at the top of the screen.</w:t></w:r></w:p><w:p w14:paraId="1E263765" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Acceptance Criteria:</w:t></w:r></w:p><w:p w14:paraId="3B27DBBC" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">The </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AppBar</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> background is transparent on non-</w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00A35FB7"><w:t>Home</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> tabs (Map, My Events, Profile).</w:t></w:r></w:p><w:p w14:paraId="03257E10" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">The </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AppBar</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> title and icons remain visible over the gradient overlay.</w:t></w:r></w:p><w:p w14:paraId="5061D938" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>No solid colour bar appears at the top of the screen that clashes with the background image.</w:t></w:r></w:p><w:p w14:paraId="54D71608" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">The Home tab continues to use no </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AppBar</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> (hero layout).</w:t></w:r></w:p><w:p w14:paraId="5A7515D5" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:lastRenderedPageBreak/><w:t xml:space="preserve">The </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AppBar</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> must render consistently across all supported screen sizes and devices without visual glitches or layout shifts.</w:t></w:r></w:p><w:p w14:paraId="155B0FEC" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"/><w:p w14:paraId="17718E6C" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:t>As a user, I want the bottom navigation bar to automatically hide when I scroll down and reappear when I scroll up, so I have more screen space for content.</w:t></w:r></w:p><w:p w14:paraId="7A717868" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Acceptance Criteria:</w:t></w:r></w:p><w:p w14:paraId="6E25304E" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Bottom nav slides out on downward scroll (&gt;2px delta)</w:t></w:r></w:p><w:p w14:paraId="23BB0A5D" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Bottom nav slides back in on upward scroll or scroll end</w:t></w:r></w:p><w:p w14:paraId="59894629" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">Uses smooth </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>AnimatedSlide</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> transition (300ms, </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00A35FB7"><w:t>easeInOut</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00A35FB7"><w:t>)</w:t></w:r></w:p><w:p w14:paraId="02556B77" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>The navigation animation must maintain 60 FPS performance on standard mobile devices without causing UI lag or frame drops.</w:t></w:r></w:p><w:p w14:paraId="7169DA8E" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"/><w:p w14:paraId="16FBC7F5" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:r w:rsidRPr="00A35FB7"><w:t>As a user, I want search to filter results by title, description, location, and category with a short delay, so the app feels responsive without excessive rebuilds.</w:t></w:r></w:p><w:p w14:paraId="5432B4BB" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Acceptance Criteria:</w:t></w:r></w:p><w:p w14:paraId="384C42A6" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Search input is debounced at 300ms for portals and 180ms for map screens.</w:t></w:r></w:p><w:p w14:paraId="60A5B68A" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Search filters results across title, description, location, section, and category simultaneously.</w:t></w:r></w:p><w:p w14:paraId="5058BCF9" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve">Results update immediately after </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00A35FB7"><w:t>debounce</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00A35FB7"><w:t xml:space="preserve"> completes.</w:t></w:r></w:p><w:p w14:paraId="77568B6C" w14:textId="77777777" w:rsidR="00A35FB7" w:rsidRPr="00A35FB7" w:rsidRDefault="00A35FB7" w:rsidP="00A35FB7"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="00A35FB7"><w:t>Search remains respo