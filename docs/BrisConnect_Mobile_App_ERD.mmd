      varchar moderation_status
      datetime created_at
    }

    ATTRACTIONS {
      varchar id PK
      varchar name
      varchar moderation_status
      datetime created_at
    }

    ATTRACTION_DETAILS {
      varchar attraction_id PK,FK
      varchar address
      decimal rating
      int review_count
    }

    EVENT_REPORTS {
      varchar id PK
      varchar event_id FK
      varchar visitor_email FK
      varchar status
      datetime created_at
    }

    APP_FEEDBACK {
      varchar id PK
