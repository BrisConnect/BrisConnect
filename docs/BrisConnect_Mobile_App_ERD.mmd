      varchar action
      text notes
      datetime reviewed_at
    }

    LOCAL_ACCOUNT_REVIEW_LOG {
      varchar id PK
      varchar local_email FK
      varchar admin_email FK
      varchar action
      text notes
      datetime reviewed_at
    }

    USER_NOTIFICATIONS {
      varchar id PK
      varchar event_id FK
      varchar user_email
      varchar user_type
      bool is_read
      datetime created_at
    }

    DISCOVER_ITEMS {
      varchar id PK
      varchar title
      varchar section
      varchar created_by_local_email FK
      varchar source
      varchar source_provider
      varchar source_place_id
      datetime updated_at
    }

    BRISBANE_STORIES {
      varchar id PK
      varchar title
      varchar category
      varchar approval_status
      datetime created_at
    }

    BRISBANE_VOICES {
      varchar id PK
      varchar name
      varchar approval_status
      datetime created_at
    }

    MAIL {
      varchar id PK
      varchar to
      json message
      json meta
      datetime created_at
    }

    SMS_QUEUE {
      varchar id PK
      varchar to
      varchar message
      json meta
      datetime created_at
    }

    COUNTERS {
      varchar id PK
      bigint count_value
    }

    CONFIG {
      varchar id PK
      json payload
    }

    SEED_METADATA {
      varchar id PK
      int version
      varchar source_provider
      int discover_item_count
      int attraction_count
      int event_count
      datetime seeded_at
      datetime last_synced_at
    }

    CONNECTIVITY_PROBE {
      varchar id PK
      json payload
    }

    VISITOR_USER_INTERESTED_EVENTS {
      varchar visitor_email PK,FK
      varchar event_id PK,FK
      datetime created_at
    }

    VISITOR_USER_SAVED_ATTRACTIONS {
      varchar visitor_email PK,FK
