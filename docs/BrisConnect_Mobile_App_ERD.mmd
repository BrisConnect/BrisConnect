erDiagram
    ADMINS {
      varchar email PK
      varchar username
      varchar role
      bool active
      datetime created_at
    }

    AFFILIATIONS {
      varchar id PK
      varchar name
      varchar type
      varchar suburb
      varchar status
      datetime created_at
    }

    ADMIN_AFFILIATIONS {
      varchar admin_email PK,FK
      varchar affiliation_id PK,FK
      varchar access_scope
      datetime assigned_at
      varchar assigned_by_admin_email FK
    }

    LOCAL_USERS {
      varchar email PK
      varchar username
      varchar name
      varchar affiliation_id FK
      varchar approval_status
      varchar account_type
      datetime created_at
    }

